# NFT Artworks — environment variables
# Copy to .env and fill values (do not commit .env)

# Pinata JWT (required for uploads + listing)
# Get from: https://app.pinata.cloud/keys
# Permissions: Files → Write, pinJSONToIPFS, pinList
PINATA_JWT=your_pinata_jwt_token_here

# Pinata gateway domain (no https://)
# Must match on server and client
PINATA_GATEWAY=your-gateway-subdomain.mypinata.cloud
VITE_PINATA_GATEWAY=your-gateway-subdomain.mypinata.cloud

# Local API server port
API_PORT=3001